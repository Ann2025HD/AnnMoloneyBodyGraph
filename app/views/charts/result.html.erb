
  <%#--------------------------------
    PAGE TITLE CARD
---------------------------------%>
<div class="chart-title-card">
  <h1 class="chart-title">Your Human Design Chart</h1>
</div>

<%#--------------------------------
    PLANET SYMBOL LOOKUP
---------------------------------%>

<%
  planet_symbols = {
    "Sun" => "☉",
    "Earth" => "⊕",
    "Moon" => "☽",
    "Mercury" => "☿",
    "Venus" => "♀",
    "Mars" => "♂",
    "Jupiter" => "♃",
    "Saturn" => "♄",
    "Uranus" => "♅",
    "Neptune" => "♆",
    "Pluto" => "♇",
    "North Node" => "☊",
    "South Node" => "☋"
  }
%>
<%#--------------------------------
    MAIN CHART
---------------------------------%>

<div class="chart-result">

  <div class="chart-layout">


<section class="panel design-panel">

    <h3>Design</h3>

    <% @chart[:design_planets].each do |planet, gate_line| %>
        <div class="planet-row">
          <span class="planet-symbol">
            <%= planet_symbols[planet] || planet %>
          </span>
          <span>
            <%= gate_line %>
          </span>
        </div>
      <% end %>

    </section>

    <section class="bodygraph">
      <%= @chart[:svg].html_safe %>
    </section>

    <section class="panel personality-panel">

    <h3>Personality</h3>

    <% @chart[:personality_planets].each do |planet, gate_line| %>
    <div class="planet-row">
      <span class="planet-symbol">
       <%= planet_symbols[planet] || planet %>
     </span>
     <span>
       <%= gate_line %>
     </span>
      </div>
    <% end %>

    </section>
  </div>

<%#--------------------------------
    CHART PROPERTIES
---------------------------------%>

<section class="properties-section">

  <div class="properties-two-column">
  <div>
    <div class="property-row">
      <span class="property-label">Name</span>
      <span class="property-value"><%= @name %></span>
   </div>
 
      <div class="property-row">
        <span class="property-label">Type</span>
        <span class="property-value"><%= @chart[:type] %></span>
      </div>

      <div class="property-row">
        <span class="property-label">Strategy</span>
        <span class="property-value"><%= @chart[:strategy] %></span>
      </div>

      <div class="property-row">
        <span class="property-label">Authority</span>
        <span class="property-value"><%= @chart[:authority] %></span>
      </div>
    </div>

    <div>
      <div class="property-row">
        <span class="property-label">Definition</span>
        <span class="property-value"><%= @chart[:definition] %></span>
      </div>

      <div class="property-row">
        <span class="property-label">Profile</span>
        <span class="property-value"><%= @chart[:profile] %></span>
      </div>

      <div class="property-row">
        <span class="property-label">Not-Self Theme</span>
        <span class="property-value"><%= @chart[:not_self] %></span>
      </div>

        <div class="property-row">
          <span class="property-label">Signature</span>
          <span class="property-value"><%= @chart[:signature] %></span>
        </div>
    </div>
  </div>

      <div class="property-row">
        <span class="property-label">Incarnation Cross</span>
       <span class="property-value"><%= @chart[:cross] %></span>
  </div>

  <div class="property-row">
       <span class="property-label">Birth Data</span>
       <span class="property-value">
       <%= @date %> • <%= @time %> • <%= @place %>
     </span>
   </div>

  
</section>
<%#--------------------------------
    GUIDE SIGNUP
---------------------------------%>


<section class="chart-guide-signup">

  <h2 class="signup-title">
    Would you like to understand your Human Design chart?
  </h2>

  <h3 class="signup-subtitle">
    Get your FREE Guide to understanding your chart
  </h3>

  <div class="signup-content">


<div class="signup-image">
  <%= image_tag "free-chart-guide-cover.png",
      alt: "Free Human Design Guide" %>
</div>

    <div class="signup-copy">
      <p class="signup-intro">
        Now that you have your chart, this guide will help you make sense of it.
      </p>

      <p class="signup-description">
        Your chart is a map — but this guide helps you read it. It walks you through the key parts of your design — your Strategy, Authority, and energy type — so you can begin to make sense of what your chart reveals about how you’re meant   to move through life.
        </p>

<%#--------------------------------
    MAILERLITE
---------------------------------%>



   <div class="signup-form">
     <form class="ml-block-form"
       action="https://assets.mailerlite.com/jsonp/1270515/forms/170060695284483242/subscribe"
       method="post"
       target="ml_hidden_iframe"
       onsubmit="setTimeout(function(){ window.location.href='https://annmoloney.com/free-chart-thank-you/'; }, 800);">    

      <input 
        type="text" 
        name="fields[name]" 
        placeholder="Name" 
        autocomplete="given-name">

      <input 
        type="email" 
        name="fields[email]" 
        placeholder="Email" 
        autocomplete="email" 
        required>

      <input type="hidden" name="ml-submit" value="1">
      <input type="hidden" name="anticsrf" value="true">

      <button type="submit">Get Your Free Guide</button>
     </form>
     <iframe name="ml_hidden_iframe" style="display:none;"></iframe>
    </div>

  </div>
</div>
